---
---

<div id="photo-screen" class="hidden min-h-dvh w-full flex flex-col items-center justify-center px-5 py-8 bg-owl-bg">
  <div class="w-full max-w-md">
    <div class="mb-8">
      <button id="back-from-photo" class="flex items-center gap-1 text-owl-text-muted font-bold mb-6 hover:text-owl-text transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back
      </button>
      <h2 class="text-2xl font-extrabold text-owl-text mb-1">Take a photo</h2>
      <p class="text-owl-text-muted font-semibold">Get a clear shot of the controls</p>
    </div>

    <!-- Viewfinder Area -->
    <div class="bg-owl-bg-alt rounded-2xl border-2 border-dashed border-owl-border-heavy p-8 mb-6">
      <img id="photo-preview" class="hidden w-full rounded-xl object-cover" alt="Photo preview" />

      <input type="file" id="file-input" accept="image/*" capture="environment" class="hidden" />

      <div id="upload-area" class="flex flex-col items-center gap-5">
        <!-- Camera icon -->
        <div class="w-20 h-20 rounded-2xl bg-owl-border flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#AFAFAF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
        </div>

        <p class="text-owl-text-muted font-semibold text-sm">Tap to snap a photo</p>

        <!-- Camera Button - Blue 3D -->
        <button
          id="camera-btn"
          class="btn-3d w-full bg-owl-blue text-white py-3 rounded-xl font-bold border-b-4 border-owl-blue-dark flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
          Open Camera
        </button>

        <p class="text-xs text-owl-text-light font-semibold">or</p>

        <!-- Gallery Button - White 3D -->
        <button
          id="gallery-btn"
          class="btn-3d w-full bg-owl-surface text-owl-text py-3 rounded-xl font-bold border-2 border-owl-border border-b-4 border-b-owl-border-heavy flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          Upload from Gallery
        </button>
      </div>

      <!-- Photo Actions (shown after capture) -->
      <div id="photo-actions" class="hidden w-full flex flex-col gap-3 mt-4">
        <button
          id="continue-from-photo"
          class="btn-3d w-full bg-owl-green text-white py-3 rounded-xl font-bold border-b-4 border-owl-green-dark uppercase tracking-wide"
        >
          Use This Photo
        </button>
        <button
          id="retake-photo"
          class="btn-3d w-full bg-owl-surface text-owl-text py-3 rounded-xl font-bold border-2 border-owl-border border-b-4 border-b-owl-border-heavy"
        >
          Retake Photo
        </button>
      </div>
    </div>

    <p class="text-xs text-owl-text-light text-center font-semibold">
      Tip: Get a clear shot of the control panel for best results
    </p>
  </div>
</div>
