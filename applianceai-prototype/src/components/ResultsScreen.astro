---
---

<div id="results-screen" class="hidden min-h-screen w-full flex flex-col items-center justify-start px-6 py-8 bg-surface">
  <div class="w-full max-w-md">
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-primary mb-2">Here's how to use it</h2>
      <p class="text-gray-500">Follow these steps carefully</p>
    </div>

    <div id="model-card" class="bg-white rounded-lg border-2 border-gray-200 p-6 mb-6 shadow-sm">
      <div class="flex items-start justify-between mb-4">
        <div>
          <p class="text-sm text-gray-500 mb-1">Identified Appliance</p>
          <h3 id="model-name" class="text-xl font-bold text-primary">
            Loading...
          </h3>
        </div>
        <div id="confidence-badge" class="px-3 py-1 rounded-full text-white font-bold text-sm bg-green-500">
          High
        </div>
      </div>
      <p id="model-disclaimer" class="text-xs text-gray-500">
        Always verify against your appliance's manual
      </p>
    </div>

    <div id="time-estimate" class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded mb-6 hidden">
      <p class="text-sm font-bold text-blue-900">
        ⏱️ <span id="time-text">5-10 minutes</span>
      </p>
    </div>

    <div id="steps-container" class="space-y-4 mb-6">
    </div>

    <div id="safety-section" class="bg-red-50 border-l-4 border-accent p-4 rounded mb-6 hidden">
      <h4 class="font-bold text-primary mb-3">Safety Tips</h4>
      <ul id="safety-list" class="space-y-2">
      </ul>
    </div>

    <button id="scan-another-btn" class="w-full bg-accent text-white py-4 rounded-lg font-bold text-lg hover:bg-red-600 transition-all shadow-lg">
      Scan Another
    </button>

    <p class="text-xs text-gray-400 text-center mt-4">
      Having issues? Check your appliance's user manual for complete instructions
    </p>
  </div>
</div>
