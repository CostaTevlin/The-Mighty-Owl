---
---

<div id="results-screen" class="hidden min-h-dvh w-full flex flex-col items-center justify-start px-5 py-8 bg-otto-bg">
  <div class="w-full max-w-md">
    <!-- Top nav -->
    <div class="flex items-center justify-between mb-4">
      <button id="start-over-btn" class="flex items-center gap-1 text-otto-ink-mid font-heading font-bold hover:text-otto-ink transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Start Over
      </button>
    </div>

    <!-- Header with celebration -->
    <div class="mb-8 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-otto-amber-pale mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#E8820C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
        </svg>
      </div>
      <h2 class="text-3xl font-heading font-extrabold text-otto-ink mb-1 tracking-tight">Here's how.</h2>
      <p class="text-otto-ink-mid font-body italic">Otto found the steps for you</p>
    </div>

    <!-- Model Identification Card -->
    <div id="model-card" class="bg-otto-surface rounded-2xl border-2 border-otto-border border-b-4 border-b-otto-border-heavy p-5 mb-5">
      <div class="flex items-start justify-between mb-3">
        <div>
          <p class="text-xs text-otto-ink-mid font-heading font-bold uppercase tracking-wider mb-1">Identified Appliance</p>
          <h3 id="model-name" class="text-xl font-heading font-extrabold text-otto-ink">
            Loading...
          </h3>
        </div>
        <div id="confidence-badge" class="px-3 py-1 rounded-full font-heading font-bold text-xs bg-otto-amber-pale text-otto-amber-deep">
          High
        </div>
      </div>
      <p id="model-disclaimer" class="text-xs text-otto-ink-soft font-body italic">
        Verify with your appliance manual
      </p>
    </div>

    <!-- Low confidence block -->
    <div id="low-confidence-block" class="hidden bg-otto-surface rounded-2xl border-2 border-otto-border border-b-4 border-b-otto-border-heavy p-5 mb-5">
      <div class="text-center mb-4">
        <span class="text-4xl">😕</span>
        <h3 class="text-xl font-heading font-extrabold text-otto-ink mt-2 mb-2">Couldn't get a clear read</h3>
        <p id="low-confidence-reason" class="text-sm font-body text-otto-ink-mid leading-relaxed"></p>
      </div>
      <div class="bg-otto-bg-alt rounded-xl p-4 mb-4">
        <p class="text-xs font-heading font-bold text-otto-ink-mid uppercase tracking-wider mb-2">Tips for a better photo</p>
        <ul class="space-y-1">
          <li class="text-sm font-body font-medium text-otto-ink">• Move closer so the label is readable</li>
          <li class="text-sm font-body font-medium text-otto-ink">• Make sure the whole appliance is in frame</li>
          <li class="text-sm font-body font-medium text-otto-ink">• Try better lighting or turn on a light nearby</li>
        </ul>
      </div>
      <button id="retake-from-results" class="btn-3d w-full bg-otto-amber text-white py-3 rounded-xl font-heading font-bold border-b-4 border-otto-amber-deep uppercase tracking-wide mb-2">
        Retake Photo
      </button>
      <p class="text-xs text-otto-ink-soft text-center font-body italic">No credit used — try again free</p>
    </div>

    <!-- Medium confidence banner (shown above steps) -->
    <div id="medium-confidence-banner" class="hidden bg-otto-amber-pale rounded-xl border-l-4 border-otto-amber p-3 mb-4">
      <p class="text-sm font-heading font-bold text-otto-amber-deep">⚠️ Brand not identified — instructions are for <span id="medium-confidence-type"></span> in general</p>
    </div>

    <!-- Quick Answer -->
    <div id="quick-answer" class="bg-otto-amber-pale rounded-2xl border-2 border-otto-amber border-b-4 border-b-otto-amber-deep p-4 mb-5 hidden">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">👉</span>
        <h4 class="font-heading font-extrabold text-otto-amber-deep text-sm uppercase tracking-wider">Quick Answer</h4>
      </div>
      <p id="quick-answer-text" class="text-sm font-body font-medium text-otto-ink leading-relaxed"></p>
    </div>

    <!-- Time Estimate -->
    <div id="time-estimate" class="bg-otto-teal-pale rounded-xl p-4 mb-5 hidden flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A8A7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <p class="text-sm font-heading font-bold text-[#147A6B]">
        <span id="time-text">5-10 minutes</span>
      </p>
    </div>

    <!-- Steps -->
    <div id="steps-container" class="space-y-3 mb-5">
    </div>

    <!-- Common Mistakes -->
    <div id="mistakes-section" class="bg-otto-amber-pale rounded-xl border-l-4 border-otto-amber p-4 mb-5 hidden">
      <div class="flex items-center gap-2 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8820C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <h4 class="font-heading font-extrabold text-otto-amber-deep text-sm">Watch Out</h4>
      </div>
      <ul id="mistakes-list" class="space-y-2"></ul>
    </div>

    <!-- Safety Tips -->
    <div id="safety-section" class="bg-otto-red-light rounded-xl border-l-4 border-otto-red p-4 mb-5 hidden">
      <div class="flex items-center gap-2 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF4B4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
        </svg>
        <h4 class="font-heading font-extrabold text-otto-red-dark text-sm">Safety Tips</h4>
      </div>
      <ul id="safety-list" class="space-y-2">
      </ul>
    </div>

    <!-- Wrong appliance correction flow (shown for high/medium only) -->
    <div id="correction-wrapper" class="hidden mb-5">
      <button id="wrong-appliance-link" class="text-sm text-otto-ink-soft font-body italic hover:text-otto-ink transition-colors duration-200">
        Wrong appliance?
      </button>
      <div id="correction-block" class="hidden mt-3 bg-otto-surface rounded-2xl border-2 border-otto-border border-b-4 border-b-otto-border-heavy p-4">
        <label class="block text-sm font-heading font-bold text-otto-ink mb-2">What appliance is this actually?</label>
        <input
          id="correction-input"
          type="text"
          placeholder="e.g. Siemens built-in oven"
          class="w-full rounded-xl border-2 border-otto-border px-3 py-2 text-sm font-body text-otto-ink bg-otto-bg outline-none focus:border-otto-amber mb-3"
        />
        <button id="correction-submit" class="btn-3d w-full bg-otto-amber text-white py-3 rounded-xl font-heading font-bold border-b-4 border-otto-amber-deep uppercase tracking-wide mb-2">
          Re-scan with this info
        </button>
        <p class="text-xs text-otto-ink-soft text-center font-body italic">This will use 1 credit</p>
      </div>
    </div>

    <!-- Scan Another CTA -->
    <button id="scan-another-btn" class="btn-3d w-full bg-otto-amber text-white py-4 rounded-2xl font-heading font-extrabold text-lg border-b-4 border-otto-amber-deep uppercase tracking-wide">
      Scan Another
    </button>

    <p id="credits-remaining-text" class="text-sm text-otto-ink-mid text-center mt-4 font-heading font-bold">
    </p>

    <p class="text-xs text-otto-ink-soft text-center mt-2 font-body italic">
      Still stuck? Your appliance manual has the full picture
    </p>
  </div>
</div>
