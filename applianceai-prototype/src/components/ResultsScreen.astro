---
---

<div id="results-screen" class="hidden min-h-dvh w-full flex flex-col items-center justify-start px-5 py-8 bg-owl-bg">
  <div class="w-full max-w-md">
    <!-- Header with celebration -->
    <div class="mb-8 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-owl-green-light mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#58CC02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
        </svg>
      </div>
      <h2 class="text-3xl font-extrabold text-owl-text mb-1">Here's how!</h2>
      <p class="text-owl-text-muted font-semibold">Follow these steps carefully</p>
    </div>

    <!-- Model Identification Card -->
    <div id="model-card" class="bg-owl-surface rounded-2xl border-2 border-owl-border border-b-4 border-b-owl-border-heavy p-5 mb-5">
      <div class="flex items-start justify-between mb-3">
        <div>
          <p class="text-xs text-owl-text-muted font-bold uppercase tracking-wider mb-1">Identified Appliance</p>
          <h3 id="model-name" class="text-xl font-extrabold text-owl-text">
            Loading...
          </h3>
        </div>
        <div id="confidence-badge" class="px-3 py-1 rounded-full font-bold text-xs bg-owl-green-light text-owl-green-dark">
          High
        </div>
      </div>
      <p id="model-disclaimer" class="text-xs text-owl-text-light font-semibold">
        Always verify against your appliance's manual
      </p>
    </div>

    <!-- Time Estimate -->
    <div id="time-estimate" class="bg-owl-blue-light rounded-xl p-4 mb-5 hidden flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1CB0F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <p class="text-sm font-bold text-owl-blue-dark">
        <span id="time-text">5-10 minutes</span>
      </p>
    </div>

    <!-- Steps -->
    <div id="steps-container" class="space-y-3 mb-5">
    </div>

    <!-- Safety Tips -->
    <div id="safety-section" class="bg-owl-red-light rounded-xl border-l-4 border-owl-red p-4 mb-6 hidden">
      <div class="flex items-center gap-2 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF4B4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
        </svg>
        <h4 class="font-extrabold text-owl-red-dark text-sm">Safety Tips</h4>
      </div>
      <ul id="safety-list" class="space-y-2">
      </ul>
    </div>

    <!-- Scan Another CTA -->
    <button id="scan-another-btn" class="btn-3d w-full bg-owl-green text-white py-4 rounded-2xl font-extrabold text-lg border-b-4 border-owl-green-dark uppercase tracking-wide">
      Scan Another
    </button>

    <p class="text-xs text-owl-text-light text-center mt-4 font-semibold">
      Having issues? Check your appliance's user manual for complete instructions
    </p>
  </div>
</div>
