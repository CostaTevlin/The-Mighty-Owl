---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="welcome-screen" class="min-h-dvh w-full flex flex-col" style="background-color: #FEFEFE;">

  <!-- Otto Hero Zone — pure white, mascot as focal point -->
  <div class="relative flex-1 flex items-end justify-center pb-4 pt-14 overflow-hidden">
    <img
      src={`${base}/images/otto-welcome.png`}
      alt="Otto the Otter mascot"
      width="240"
      height="240"
      class="relative w-[220px] sm:w-[260px] h-auto"
    />
  </div>

  <!-- Content card — cream bg slides up from below -->
  <div
    class="bg-otto-bg rounded-t-[2rem] px-5 pt-8 pb-10"
    style="box-shadow: 0 -4px 32px rgba(26,16,8,0.07);"
  >
    <div class="max-w-md mx-auto text-center">

      <h1 class="text-4xl font-heading font-extrabold text-otto-ink mb-1 tracking-tight">
        Otto
      </h1>
      <p class="text-base text-otto-ink-mid font-body italic mb-7">
        Snap. Learn. Done.
      </p>

      <!-- Flow Steps -->
      <div class="flex items-center justify-center gap-3 mb-7">
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-2xl bg-otto-amber-pale flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E8820C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
              <circle cx="12" cy="13" r="3"/>
            </svg>
          </div>
          <span class="text-xs font-heading font-bold text-otto-ink-mid">Snap</span>
        </div>

        <div class="w-8 border-t-2 border-dashed border-otto-border-heavy mt-[-20px]"></div>

        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-2xl bg-otto-teal-pale flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1A8A7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="16" height="16" x="4" y="4" rx="2"/>
              <rect width="6" height="6" x="9" y="9" rx="1"/>
              <path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>
            </svg>
          </div>
          <span class="text-xs font-heading font-bold text-otto-ink-mid">Otto Reads</span>
        </div>

        <div class="w-8 border-t-2 border-dashed border-otto-border-heavy mt-[-20px]"></div>

        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-2xl bg-otto-amber-pale flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#B85F05" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3.5 5.5 2 7l1.5 1.5"/><path d="M8.5 5.5 10 7 8.5 8.5"/><path d="m5 6 1 2"/><path d="m2 12 10 0"/><path d="m2 16 10 0"/><path d="m2 20 10 0"/><path d="m14 12 8 0"/><path d="m14 16 8 0"/><path d="m14 20 8 0"/>
            </svg>
          </div>
          <span class="text-xs font-heading font-bold text-otto-ink-mid">Get Steps</span>
        </div>
      </div>

      <!-- CTA Button -->
      <button
        id="get-started-btn"
        class="btn-3d w-full bg-otto-amber text-white py-4 rounded-2xl font-heading font-extrabold text-lg border-b-4 border-otto-amber-deep uppercase tracking-wide mb-4"
      >
        Get Started
      </button>

      <p class="text-sm text-otto-ink-mid font-heading font-bold mb-2">
        3 free scans included — no account needed
      </p>
      <p class="text-xs text-otto-ink-soft font-body italic">
        Works with washing machines, ovens, coffee makers & more
      </p>

    </div>
  </div>
</div>
