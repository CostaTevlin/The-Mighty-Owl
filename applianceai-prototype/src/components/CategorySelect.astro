---
---

<div id="category-screen" class="hidden min-h-dvh w-full flex flex-col items-center justify-center px-5 py-8 bg-owl-bg">
  <div class="w-full max-w-md">
    <div class="mb-8">
      <button id="back-from-category" class="flex items-center gap-1 text-owl-text-muted font-bold mb-6 hover:text-owl-text transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back
      </button>
      <h2 class="text-2xl font-extrabold text-owl-text mb-1">Pick your appliance</h2>
      <p class="text-owl-text-muted font-semibold">Choose one to get tailored instructions</p>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <!-- Washing Machine -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="washing"
      >
        <div class="w-12 h-12 rounded-xl bg-owl-blue-light flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1CB0F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Washing Machine</span>
      </button>

      <!-- Oven / Stove -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="cooking"
      >
        <div class="w-12 h-12 rounded-xl bg-[#FFF3E0] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF9600" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Oven / Stove</span>
      </button>

      <!-- Coffee Machine -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="coffee"
      >
        <div class="w-12 h-12 rounded-xl bg-[#F3E5F5] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CE82FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Coffee Machine</span>
      </button>

      <!-- Dishwasher -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="dishwashing"
      >
        <div class="w-12 h-12 rounded-xl bg-owl-blue-light flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1CB0F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15.236 22a3 3 0 0 0-2.2-5"/><path d="M16 20a3 3 0 0 1 3-3h1a2 2 0 0 0 2-2v-2a4 4 0 0 0-4-4V4"/><path d="M3 13a2 2 0 0 1 2-2h6.586a1 1 0 0 1 .707.293l4.414 4.414a1 1 0 0 1-.707 1.707H5a2 2 0 0 1-2-2Z"/><path d="M8 13v-2a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Dishwasher</span>
      </button>

      <!-- Dryer -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="drying"
      >
        <div class="w-12 h-12 rounded-xl bg-owl-green-light flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#58CC02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Dryer</span>
      </button>

      <!-- Other -->
      <button
        class="category-card btn-3d bg-owl-surface border-2 border-owl-border border-b-4 border-b-owl-border-heavy rounded-2xl flex flex-col items-center justify-center gap-3 p-5 min-h-[120px] hover:border-owl-green transition-colors duration-200"
        data-category="other"
      >
        <div class="w-12 h-12 rounded-xl bg-owl-bg-alt flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#777777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-owl-text">Other</span>
      </button>
    </div>
  </div>
</div>
