---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="paywall-screen" class="min-h-dvh w-full flex flex-col hidden" style="background-color: #FEFEFE;">

  <!-- Otto Hero Zone -->
  <div class="relative flex-1 flex items-end justify-center pb-2 pt-14 overflow-hidden">
    <img
      src={`${base}/images/otto-explaining.png`}
      alt="Otto explaining"
      width="340"
      height="227"
      class="relative w-[320px] sm:w-[360px] h-auto"
    />
  </div>

  <!-- Content card -->
  <div
    class="bg-otto-bg rounded-t-[2rem] px-5 pt-8 pb-10 overflow-y-auto"
    style="box-shadow: 0 -4px 32px rgba(26,16,8,0.07);"
  >
    <div class="max-w-md mx-auto text-center">

      <h1 id="paywall-title" class="text-2xl font-heading font-extrabold text-otto-ink mb-2 tracking-tight">Running low on scans</h1>
      <p id="paywall-subtitle" class="text-otto-ink-mid font-body italic mb-8">Grab a top-up and keep going</p>

      <div class="bg-otto-amber-pale rounded-2xl border-2 border-otto-amber p-5 mb-4 relative">
        <span class="absolute top-0 right-4 -translate-y-1/2 bg-otto-amber text-white text-xs font-heading font-extrabold px-3 py-1 rounded-full uppercase">
          Best Value
        </span>
        <div class="text-left mb-3">
          <p class="text-xl font-heading font-extrabold text-otto-ink">Lifetime Pro</p>
          <p class="text-sm text-otto-ink-mid font-body italic">500 scans — use anytime, no expiry</p>
        </div>
        <div class="flex items-baseline gap-2 mb-4">
          <span class="text-3xl font-heading font-extrabold text-otto-amber-deep">$9.99</span>
          <span class="text-sm text-otto-ink-mid font-body">one-time</span>
        </div>
        <button
          id="buy-lifetime"
          class="btn-3d w-full bg-otto-amber text-white border-b-4 border-otto-amber-deep py-3 rounded-xl font-heading font-extrabold text-base uppercase"
        >
          <span id="buy-lifetime-default">Get Lifetime Pro</span>
          <span id="buy-lifetime-success" class="hidden">&#10003; Unlocked!</span>
        </button>
      </div>

      <div class="bg-otto-surface rounded-2xl border-2 border-otto-border border-b-4 border-b-otto-border-heavy p-5 mb-6">
        <div class="text-left mb-3">
          <p class="text-lg font-heading font-extrabold text-otto-ink">Top-up Pack</p>
          <p class="text-sm text-otto-ink-mid font-body italic">150 scans</p>
        </div>
        <div class="flex items-baseline gap-2 mb-4">
          <span class="text-2xl font-heading font-extrabold text-otto-ink">$2.99</span>
        </div>
        <button
          id="buy-topup"
          class="btn-3d w-full bg-otto-teal text-white border-b-4 border-[#147A6B] py-3 rounded-xl font-heading font-extrabold text-base uppercase"
        >
          <span id="buy-topup-default">Get Top-up</span>
          <span id="buy-topup-success" class="hidden">&#10003; Unlocked!</span>
        </button>
      </div>

      <button id="back-from-paywall" class="text-sm text-otto-ink-mid font-heading font-bold hover:text-otto-ink transition-colors duration-200">
        Maybe later
      </button>

    </div>
  </div>
</div>
