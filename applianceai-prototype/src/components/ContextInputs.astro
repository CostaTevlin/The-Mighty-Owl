---
---

<div id="context-screen" class="hidden min-h-dvh w-full flex flex-col items-center justify-start px-5 pt-6 pb-12 bg-otto-bg">
  <div class="w-full max-w-md">
    <div class="mb-8">
      <div class="grid grid-cols-3 items-center mb-6">
        <button id="back-from-context" class="flex items-center gap-1 text-otto-ink-mid font-heading font-bold hover:text-otto-ink transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back
        </button>
        <span class="text-xs font-heading font-bold text-otto-ink-soft tracking-wide text-center">Step 3 of 4</span>
        <div></div>
      </div>
      <h2 class="text-2xl font-heading font-extrabold text-otto-ink mb-1 tracking-tight">One more thing</h2>
      <p class="text-otto-ink-mid font-body italic">Your answers sharpen Otto's advice</p>
    </div>

    <form id="context-form" class="space-y-6">
      <!-- Washing -->
      <div id="washing-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Load Size</label>
          <div class="flex justify-between gap-2">
            <button type="button" class="load-size-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="small">Small</button>
            <button type="button" class="load-size-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="medium">Medium</button>
            <button type="button" class="load-size-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="large">Large</button>
          </div>
          <input type="hidden" id="load-size" name="loadSize" value="" />
        </div>
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Wash Colour</label>
          <div class="flex justify-between gap-2">
            <button type="button" class="color-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="whites">Whites</button>
            <button type="button" class="color-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="colored">Coloured</button>
            <button type="button" class="color-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="mixed">Mixed</button>
          </div>
          <input type="hidden" id="wash-color" name="washColor" value="" />
        </div>
      </div>

      <!-- Cooking -->
      <div id="cooking-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">What are you cooking?</label>
          <input type="text" id="cooking-item" name="cookingItem" placeholder="e.g., pizza, cookies, leftovers..." class="w-full px-4 py-3 rounded-xl border-2 border-otto-border bg-otto-bg-alt focus:border-otto-amber focus:outline-none focus:ring-2 focus:ring-otto-amber-pale transition-colors duration-200 font-body text-otto-ink placeholder:text-otto-ink-soft" />
        </div>
      </div>

      <!-- Coffee -->
      <div id="coffee-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Drink Type</label>
          <div class="grid grid-cols-2 gap-3">
            <button type="button" class="coffee-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="espresso">Espresso</button>
            <button type="button" class="coffee-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="latte">Latte</button>
            <button type="button" class="coffee-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="drip">Drip</button>
            <button type="button" class="coffee-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="cappuccino">Cappuccino</button>
          </div>
          <input type="hidden" id="coffee-type" name="coffeeType" value="" />
        </div>
      </div>

      <!-- Dishwashing -->
      <div id="dishwashing-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Load Level</label>
          <div class="flex gap-2">
            <button type="button" class="load-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="half">Half Load</button>
            <button type="button" class="load-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="full">Full Load</button>
          </div>
          <input type="hidden" id="load-level" name="loadLevel" value="" />
        </div>
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Soil Level</label>
          <div class="flex gap-2">
            <button type="button" class="soil-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="light">Light</button>
            <button type="button" class="soil-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="normal">Normal</button>
            <button type="button" class="soil-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold bg-otto-surface border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink transition-colors duration-200" data-value="heavy">Heavy</button>
          </div>
          <input type="hidden" id="soil-level" name="soilLevel" value="" />
        </div>
      </div>

      <!-- Drying -->
      <div id="drying-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Fabric Type</label>
          <div class="grid grid-cols-3 gap-2">
            <button type="button" class="fabric-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="cotton">Cotton</button>
            <button type="button" class="fabric-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="synthetic">Synthetic</button>
            <button type="button" class="fabric-type-btn btn-3d-sm py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="delicate">Delicate</button>
          </div>
          <input type="hidden" id="fabric-type" name="fabricType" value="" />
        </div>
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Heat Level</label>
          <div class="flex gap-2">
            <button type="button" class="heat-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="low">Low</button>
            <button type="button" class="heat-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="medium">Medium</button>
            <button type="button" class="heat-level-btn btn-3d-sm flex-1 py-3 rounded-xl font-heading font-bold border-2 border-otto-border border-b-4 border-b-otto-border-heavy text-otto-ink text-sm transition-colors duration-200" data-value="high">High</button>
          </div>
          <input type="hidden" id="heat-level" name="heatLevel" value="" />
        </div>
      </div>

      <!-- Other -->
      <div id="other-inputs" class="hidden space-y-6">
        <div>
          <label class="block text-xs font-heading font-bold text-otto-ink uppercase tracking-wider mb-3">Describe the appliance or task</label>
          <textarea id="other-description" name="description" placeholder="e.g., smart TV remote, air fryer, water heater..." rows="4" class="w-full px-4 py-3 rounded-xl border-2 border-otto-border bg-otto-bg-alt focus:border-otto-amber focus:outline-none focus:ring-2 focus:ring-otto-amber-pale transition-colors duration-200 resize-none font-body text-otto-ink placeholder:text-otto-ink-soft"></textarea>
        </div>
      </div>

      <button type="submit" class="btn-3d w-full bg-otto-amber text-white py-4 rounded-2xl font-heading font-extrabold text-lg border-b-4 border-otto-amber-deep uppercase tracking-wide">
        Teach Me
      </button>
    </form>
  </div>
</div>
