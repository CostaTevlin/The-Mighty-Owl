---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="loading-screen" class="hidden min-h-dvh w-full flex flex-col" style="background-color: #FEFEFE;">

  <!-- Otto Hero Zone -->
  <div class="relative flex-1 flex items-end justify-center pb-4 pt-14 overflow-hidden">
    <div id="loading-emoji" class="relative">
      <img
        src={`${base}/images/otto-analyzing.png`}
        alt="Otto analyzing"
        width="200"
        height="200"
        class="w-[220px] sm:w-[260px] h-auto"
      />
    </div>
  </div>

  <!-- Content card -->
  <div
    class="bg-otto-bg rounded-t-[2rem] px-5 pt-8 pb-10"
    style="box-shadow: 0 -4px 32px rgba(26,16,8,0.07);"
  >
    <div class="max-w-md mx-auto text-center">

      <!-- Status Message -->
      <div class="mb-8 h-14 flex items-center justify-center">
        <div id="loading-message" class="text-xl font-heading font-extrabold text-otto-ink animate-fade-in" aria-live="polite" aria-atomic="true">
          Scanning your appliance...
        </div>
      </div>

      <!-- Progress Bar -->
      <div class="w-full bg-otto-bg-alt rounded-full h-3 overflow-hidden border border-otto-border mb-6">
        <div id="progress-bar" class="bg-otto-amber h-full rounded-full relative overflow-hidden transition-all duration-700 ease-in-out" style="width: 10%;">
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent" style="animation: shimmer 1.5s infinite;"></div>
        </div>
      </div>

      <div class="bg-otto-bg-alt rounded-2xl border border-otto-border p-4 text-left w-full">
        <p class="text-xs font-heading font-bold text-otto-ink-mid uppercase tracking-wider mb-1">Did you know?</p>
        <p class="text-sm font-body text-otto-ink-mid leading-relaxed italic">Most appliance errors come from one skipped step — that's exactly what Otto looks for.</p>
      </div>

    </div>
  </div>
</div>
