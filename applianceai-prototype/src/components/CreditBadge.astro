---

<button
  id="credit-badge"
  data-credits="3"
  aria-label="Credits remaining — tap to manage"
  class="fixed top-4 right-4 z-50 flex items-center gap-1.5 px-3 py-1.5 bg-otto-bg rounded-full border-2 border-otto-border shadow-sm font-heading cursor-pointer hover:border-otto-amber transition-colors duration-200"
  style="border-bottom-width: 3px; border-bottom-color: #C8BBAA;"
>
  <svg
    width="14"
    height="14"
    viewBox="0 0 14 14"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M8.5 1L3 8h4.5L5.5 13 11 6H6.5L8.5 1z"
      fill="#E8820C"
      stroke="#B85F05"
      stroke-width="0.75"
      stroke-linejoin="round"
    />
  </svg>
  <span id="credit-count" class="text-sm font-heading font-bold text-otto-ink leading-none">3</span>
</button>
