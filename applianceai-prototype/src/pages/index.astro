---
import Layout from '../layouts/Layout.astro';
import WelcomeScreen from '../components/WelcomeScreen.astro';
import CategorySelect from '../components/CategorySelect.astro';
import PhotoCapture from '../components/PhotoCapture.astro';
import ContextInputs from '../components/ContextInputs.astro';
import LoadingState from '../components/LoadingState.astro';
import ResultsScreen from '../components/ResultsScreen.astro';
import PaywallScreen from '../components/PaywallScreen.astro';
import CreditBadge from '../components/CreditBadge.astro';
---

<Layout title="The Mighty Owl - Snap. Learn. Done.">
  <CreditBadge />
  <div id="app" class="w-full min-h-dvh bg-owl-bg">
    <WelcomeScreen />
    <CategorySelect />
    <PhotoCapture />
    <ContextInputs />
    <LoadingState />
    <ResultsScreen />
    <PaywallScreen />
  </div>

  <script>
    // ===== STATE MANAGEMENT =====
    let currentStep = 'welcome';
    let selectedCategory = null;
    let capturedImage = null;
    let contextData = {};

    const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL || '').replace(/\/$/, '');
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

    // ===== CREDITS SYSTEM =====
    const DEVICE_ID_KEY = 'owl_device_id';
    const CREDITS_KEY = 'owl_credits';
    const FREE_CREDITS = 3;

    function getDeviceId() {
      let id = localStorage.getItem(DEVICE_ID_KEY);
      if (!id) {
        id = crypto.randomUUID();
        localStorage.setItem(DEVICE_ID_KEY, id);
      }
      return id;
    }

    function getCredits() {
      const stored = localStorage.getItem(CREDITS_KEY);
      if (stored === null) {
        localStorage.setItem(CREDITS_KEY, String(FREE_CREDITS));
        return FREE_CREDITS;
      }
      return parseInt(stored, 10);
    }

    function setCredits(n) {
      localStorage.setItem(CREDITS_KEY, String(n));
      updateCreditBadge();
    }

    function updateCreditBadge() {
      const credits = getCredits();
      const badge = document.getElementById('credit-badge');
      const count = document.getElementById('credit-count');
      if (count) count.textContent = String(credits);
      if (badge) badge.setAttribute('data-credits', String(credits));

      const remaining = document.getElementById('credits-remaining-text');
      if (remaining) {
        remaining.textContent = `${credits} scan${credits !== 1 ? 's' : ''} remaining`;
      }
    }

    async function handlePurchase(product, credits, price) {
      const btnId = product === 'lifetime' ? 'buy-lifetime' : 'buy-topup';
      const btn = document.getElementById(btnId);
      const defaultSpan = document.getElementById(`${btnId}-default`);
      const successSpan = document.getElementById(`${btnId}-success`);

      if (btn) btn.disabled = true;
      if (defaultSpan) defaultSpan.textContent = 'Processing...';

      // Log purchase intent to Supabase (fire-and-forget)
      if (supabaseUrl && supabaseKey) {
        fetch(`${supabaseUrl}/functions/v1/log-purchase`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${supabaseKey}`,
          },
          body: JSON.stringify({
            deviceId: getDeviceId(),
            product,
            creditsGranted: credits,
            priceShown: price,
          }),
        }).catch((err) => console.error('Failed to log purchase:', err));
      }

      // Grant credits immediately
      setCredits(getCredits() + credits);

      // Show success state
      if (defaultSpan) defaultSpan.classList.add('hidden');
      if (successSpan) successSpan.classList.remove('hidden');

      // Navigate after brief delay
      setTimeout(() => {
        // Reset button state for next visit
        if (defaultSpan) {
          defaultSpan.textContent = product === 'lifetime' ? 'Get Lifetime Pro' : 'Get Top-up';
          defaultSpan.classList.remove('hidden');
        }
        if (successSpan) successSpan.classList.add('hidden');
        if (btn) btn.disabled = false;

        showStep('category');
      }, 1500);
    }

    // Init credits on page load
    getDeviceId();
    updateCreditBadge();

    // ===== UTILITY FUNCTIONS =====
    function showStep(stepName) {
      currentStep = stepName;

      document.getElementById('welcome-screen').classList.add('hidden');
      document.getElementById('category-screen').classList.add('hidden');
      document.getElementById('photo-screen').classList.add('hidden');
      document.getElementById('context-screen').classList.add('hidden');
      document.getElementById('loading-screen').classList.add('hidden');
      document.getElementById('results-screen').classList.add('hidden');
      document.getElementById('paywall-screen').classList.add('hidden');

      switch (stepName) {
        case 'welcome':
          document.getElementById('welcome-screen').classList.remove('hidden');
          break;
        case 'category':
          document.getElementById('category-screen').classList.remove('hidden');
          break;
        case 'photo':
          document.getElementById('photo-screen').classList.remove('hidden');
          break;
        case 'context':
          document.getElementById('context-screen').classList.remove('hidden');
          showContextInputs(selectedCategory);
          break;
        case 'loading':
          document.getElementById('loading-screen').classList.remove('hidden');
          startLoadingAnimation();
          break;
        case 'results':
          document.getElementById('results-screen').classList.remove('hidden');
          break;
        case 'paywall':
          document.getElementById('paywall-screen').classList.remove('hidden');
          break;
      }

      window.scrollTo(0, 0);
    }

    function compressImage(file, callback) {
      const reader = new FileReader();

      reader.onload = (e) => {
        const img = new Image();

        img.onload = () => {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');

          const maxSize = 768;
          let width = img.width;
          let height = img.height;

          if (width > height) {
            if (width > maxSize) {
              height = (height * maxSize) / width;
              width = maxSize;
            }
          } else {
            if (height > maxSize) {
              width = (width * maxSize) / height;
              height = maxSize;
            }
          }

          canvas.width = width;
          canvas.height = height;
          ctx.drawImage(img, 0, 0, width, height);

          const base64 = canvas.toDataURL('image/jpeg', 0.6).split(',')[1];
          callback(base64);
        };

        img.src = e.target.result;
      };

      reader.readAsDataURL(file);
    }

    function showContextInputs(category) {
      document.getElementById('washing-inputs')?.classList.add('hidden');
      document.getElementById('cooking-inputs')?.classList.add('hidden');
      document.getElementById('coffee-inputs')?.classList.add('hidden');
      document.getElementById('dishwashing-inputs')?.classList.add('hidden');
      document.getElementById('drying-inputs')?.classList.add('hidden');
      document.getElementById('other-inputs')?.classList.add('hidden');

      switch (category) {
        case 'washing':
          document.getElementById('washing-inputs')?.classList.remove('hidden');
          break;
        case 'cooking':
          document.getElementById('cooking-inputs')?.classList.remove('hidden');
          break;
        case 'coffee':
          document.getElementById('coffee-inputs')?.classList.remove('hidden');
          break;
        case 'dishwashing':
          document.getElementById('dishwashing-inputs')?.classList.remove('hidden');
          break;
        case 'drying':
          document.getElementById('drying-inputs')?.classList.remove('hidden');
          break;
        case 'other':
          document.getElementById('other-inputs')?.classList.remove('hidden');
          break;
      }
    }

    function startLoadingAnimation() {
      const messages = [
        'Spotting your appliance...',
        'Reading the controls...',
        'Analysing the display...',
        'Almost there...',
      ];
      const progressSteps = ['15%', '40%', '70%', '90%'];

      const msgEl = document.getElementById('loading-message');
      const progressEl = document.getElementById('progress-bar');

      if (msgEl) msgEl.textContent = messages[0];
      if (progressEl) progressEl.style.width = progressSteps[0];

      let index = 0;
      const interval = setInterval(() => {
        index++;
        if (index < messages.length) {
          if (msgEl) msgEl.textContent = messages[index];
          if (progressEl) progressEl.style.width = progressSteps[index];
        }
      }, 1200);

      (window).loadingInterval = interval;
    }

    function stopLoadingAnimation() {
      clearInterval((window).loadingInterval);
      const progressEl = document.getElementById('progress-bar');
      if (progressEl) progressEl.style.width = '100%';
    }

    function buildContextObject(category) {
      const context = { category };

      switch (category) {
        case 'washing':
          context.loadSize = document.getElementById('load-size')?.value;
          context.washColor = document.getElementById('wash-color')?.value;
          break;
        case 'cooking':
          context.cookingItem = document.getElementById('cooking-item')?.value;
          break;
        case 'coffee':
          context.coffeeType = document.getElementById('coffee-type')?.value;
          break;
        case 'dishwashing':
          context.loadLevel = document.getElementById('load-level')?.value;
          context.soilLevel = document.getElementById('soil-level')?.value;
          break;
        case 'drying':
          context.fabricType = document.getElementById('fabric-type')?.value;
          context.heatLevel = document.getElementById('heat-level')?.value;
          break;
        case 'other':
          context.description = document.getElementById('other-description')?.value;
          break;
      }

      return context;
    }

    async function callAnalyzeFunction(imageBase64, task, context) {
      if (!supabaseUrl || !supabaseKey) {
        throw new Error(
          'Supabase is not configured (missing PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY at build time). For GitHub Pages, add those values as repository Actions secrets so the deploy workflow can pass them into npm run build.'
        );
      }
      try {
        const functionUrl = `${supabaseUrl}/functions/v1/analyze`;

        const response = await fetch(functionUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${supabaseKey}`,
          },
          body: JSON.stringify({
            image: imageBase64,
            task: task,
            context: context,
          }),
        });

        if (!response.ok) {
          const error = await response.text();
          throw new Error(`Function call failed: ${error}`);
        }

        const result = await response.json();
        return result;
      } catch (error) {
        console.error('Error calling analyze function:', error);
        throw error;
      }
    }

    function renderResults(data) {
      document.getElementById('model-name').textContent = data.model || 'Unknown Model';

      if (data.quickAnswer) {
        const qaSection = document.getElementById('quick-answer');
        qaSection.classList.remove('hidden');
        document.getElementById('quick-answer-text').textContent = data.quickAnswer;
      }

      const badge = document.getElementById('confidence-badge');
      if (data.confidence === 'high') {
        badge.className = 'px-3 py-1 rounded-full font-bold text-xs bg-owl-green-light text-owl-green-dark';
        badge.textContent = 'High';
      } else if (data.confidence === 'medium') {
        badge.className = 'px-3 py-1 rounded-full font-bold text-xs bg-[#FFF3E0] text-owl-orange-dark';
        badge.textContent = 'Medium';
      } else {
        badge.className = 'px-3 py-1 rounded-full font-bold text-xs bg-owl-red-light text-owl-red-dark';
        badge.textContent = 'Low';
      }

      const stepsContainer = document.getElementById('steps-container');
      stepsContainer.innerHTML = '';

      if (data.steps && Array.isArray(data.steps)) {
        data.steps.forEach((step, index) => {
          const stepEl = document.createElement('div');
          stepEl.className = 'bg-owl-surface rounded-xl border-2 border-owl-border border-b-4 border-b-owl-border-heavy p-4 animate-slide-up';
          stepEl.style.animationDelay = `${index * 0.08}s`;
          const row = document.createElement('div');
          row.className = 'flex gap-3 items-start';
          const num = document.createElement('div');
          num.className = 'w-8 h-8 bg-owl-green text-white rounded-full flex items-center justify-center font-extrabold text-sm flex-shrink-0';
          num.textContent = String(index + 1);
          const p = document.createElement('p');
          p.className = 'text-owl-text text-sm leading-relaxed flex-1 font-semibold';
          p.textContent = step;
          row.appendChild(num);
          row.appendChild(p);
          stepEl.appendChild(row);
          stepsContainer.appendChild(stepEl);
        });
      }

      if (data.commonMistakes && Array.isArray(data.commonMistakes) && data.commonMistakes.length > 0) {
        const mistakesSection = document.getElementById('mistakes-section');
        mistakesSection.classList.remove('hidden');
        const mistakesList = document.getElementById('mistakes-list');
        mistakesList.innerHTML = '';
        data.commonMistakes.forEach((mistake) => {
          const li = document.createElement('li');
          li.className = 'text-sm text-owl-text flex gap-2 items-start';
          const icon = document.createElement('span');
          icon.className = 'font-bold text-owl-orange flex-shrink-0';
          icon.textContent = '✕';
          const text = document.createElement('span');
          text.className = 'font-semibold';
          text.textContent = mistake;
          li.appendChild(icon);
          li.appendChild(text);
          mistakesList.appendChild(li);
        });
      }

      if (data.safetyTips && Array.isArray(data.safetyTips) && data.safetyTips.length > 0) {
        const safetySection = document.getElementById('safety-section');
        safetySection.classList.remove('hidden');

        const safetyList = document.getElementById('safety-list');
        safetyList.innerHTML = '';

        data.safetyTips.forEach((tip) => {
          const li = document.createElement('li');
          li.className = 'text-sm text-owl-text flex gap-2 items-start';
          const dot = document.createElement('span');
          dot.className = 'w-1.5 h-1.5 rounded-full bg-owl-red mt-1.5 flex-shrink-0';
          const text = document.createElement('span');
          text.className = 'font-semibold';
          text.textContent = tip;
          li.appendChild(dot);
          li.appendChild(text);
          safetyList.appendChild(li);
        });
      }

      if (data.estimatedTime) {
        const timeSection = document.getElementById('time-estimate');
        timeSection.classList.remove('hidden');
        document.getElementById('time-text').textContent = data.estimatedTime;
      }
    }

    // ===== EVENT LISTENERS =====
    document.getElementById('get-started-btn')?.addEventListener('click', () => {
      showStep('category');
    });

    document.querySelectorAll('.category-card').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget;
        selectedCategory = target.getAttribute('data-category');
        showStep('photo');
      });
    });

    document.getElementById('back-from-category')?.addEventListener('click', () => {
      showStep('welcome');
    });

    const fileInput = document.getElementById('file-input');
    const cameraBtn = document.getElementById('camera-btn');
    const galleryBtn = document.getElementById('gallery-btn');
    const photoPreview = document.getElementById('photo-preview');
    const uploadArea = document.getElementById('upload-area');
    const photoActions = document.getElementById('photo-actions');

    function resetPhotoState() {
      capturedImage = null;
      photoPreview.src = '';
      photoPreview.classList.add('hidden');
      uploadArea?.classList.remove('hidden');
      document.getElementById('upload-buttons')?.classList.remove('hidden');
      photoActions?.classList.add('hidden');
      fileInput.value = '';
    }

    cameraBtn?.addEventListener('click', () => {
      fileInput.setAttribute('capture', 'environment');
      fileInput.click();
    });

    galleryBtn?.addEventListener('click', () => {
      fileInput.removeAttribute('capture');
      fileInput.click();
    });

    fileInput?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (event) => {
          photoPreview.src = event.target?.result;
          photoPreview.classList.remove('hidden');
          uploadArea?.classList.add('hidden');
          document.getElementById('upload-buttons')?.classList.add('hidden');
          photoActions?.classList.remove('hidden');
          capturedImage = file;
        };
        reader.readAsDataURL(file);
      }
    });

    document.getElementById('continue-from-photo')?.addEventListener('click', () => {
      showStep('context');
    });

    document.getElementById('retake-photo')?.addEventListener('click', () => {
      resetPhotoState();
    });

    document.getElementById('back-from-photo')?.addEventListener('click', () => {
      resetPhotoState();
      showStep('category');
    });

    // Button toggles — Duolingo-style chip selection
    const activeClasses = ['bg-owl-green', 'text-white', 'border-owl-green', 'border-b-owl-green-dark'];
    const inactiveClasses = ['bg-owl-bg-alt', 'border-owl-border', 'border-b-owl-border-heavy', 'text-owl-text'];

    function setupToggle(btnClass, inputId) {
      document.querySelectorAll(`.${btnClass}`).forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget;
          const value = target.getAttribute('data-value');
          document.querySelectorAll(`.${btnClass}`).forEach((b) => {
            b.classList.remove(...activeClasses);
            b.classList.add(...inactiveClasses);
          });
          target.classList.remove(...inactiveClasses);
          target.classList.add(...activeClasses);
          document.getElementById(inputId).value = value;
        });
      });
    }

    setupToggle('load-size-btn', 'load-size');
    setupToggle('color-btn', 'wash-color');
    setupToggle('coffee-type-btn', 'coffee-type');
    setupToggle('load-level-btn', 'load-level');
    setupToggle('soil-level-btn', 'soil-level');
    setupToggle('fabric-type-btn', 'fabric-type');
    setupToggle('heat-level-btn', 'heat-level');

    document.getElementById('back-from-context')?.addEventListener('click', () => {
      showStep('photo');
    });

    document.getElementById('context-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!capturedImage) {
        alert('Please capture a photo first');
        return;
      }

      // Check credits before proceeding
      if (getCredits() <= 0) {
        showStep('paywall');
        return;
      }

      contextData = buildContextObject(selectedCategory);
      showStep('loading');

      try {
        compressImage(capturedImage, async (base64) => {
          try {
            const result = await callAnalyzeFunction(base64, selectedCategory, contextData);
            stopLoadingAnimation();

            // Deduct credit after successful scan
            setCredits(getCredits() - 1);

            renderResults(result);
            showStep('results');
          } catch (error) {
            stopLoadingAnimation();
            alert(`Error: ${error.message}`);
            showStep('context');
          }
        });
      } catch (error) {
        stopLoadingAnimation();
        alert(`Error: ${error.message}`);
        showStep('context');
      }
    });

    document.getElementById('scan-another-btn')?.addEventListener('click', () => {
      contextData = {};
      resetPhotoState();
      showStep('category');
    });

    document.getElementById('start-over-btn')?.addEventListener('click', () => {
      selectedCategory = null;
      contextData = {};
      resetPhotoState();
      showStep('welcome');
    });

    // ===== CREDIT BADGE CLICK =====
    document.getElementById('credit-badge')?.addEventListener('click', () => {
      const credits = getCredits();
      const title = document.getElementById('paywall-title');
      const subtitle = document.getElementById('paywall-subtitle');
      if (credits > 0) {
        if (title) title.textContent = `You have ${credits} scan${credits !== 1 ? 's' : ''} left!`;
        if (subtitle) subtitle.textContent = 'Stock up and never run out';
      } else {
        if (title) title.textContent = "You've used your free scans!";
        if (subtitle) subtitle.textContent = 'Unlock more scans to keep going';
      }
      showStep('paywall');
    });

    // ===== PAYWALL EVENT LISTENERS =====
    document.getElementById('buy-lifetime')?.addEventListener('click', () => {
      handlePurchase('lifetime', 500, '$9.99');
    });

    document.getElementById('buy-topup')?.addEventListener('click', () => {
      handlePurchase('topup', 150, '$2.99');
    });

    document.getElementById('back-from-paywall')?.addEventListener('click', () => {
      showStep('welcome');
    });
  </script>
</Layout>
